# =============================================================================
# Whale Follower Bot — Variables de entorno
# =============================================================================
# Copia este archivo a ".env" y rellena tus valores reales.
# NUNCA subas el .env a git (ya está en .gitignore).
# =============================================================================


# ── TELEGRAM ──────────────────────────────────────────────────────────────────
#
# TELEGRAM_BOT_TOKEN
#   Cómo obtenerlo:
#   1. Abre Telegram y busca @BotFather
#   2. Envía /newbot → elige nombre → elige username (debe terminar en "bot")
#   3. BotFather te devolverá un token con formato: 123456789:ABCdef...
#
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# TELEGRAM_CHAT_ID
#   Cómo obtenerlo (2 opciones):
#   Opción A — Chat personal:
#     1. Busca @userinfobot en Telegram
#     2. Envía /start → te da tu Chat ID numérico (ej: 987654321)
#   Opción B — Grupo/canal:
#     1. Agrega @userinfobot al grupo
#     2. El ID de grupo empieza con "-" (ej: -1001234567890)
#
TELEGRAM_CHAT_ID=987654321


# ── SUPABASE ──────────────────────────────────────────────────────────────────
#
# SUPABASE_URL
#   Dónde encontrarlo:
#   1. Ve a https://supabase.com/dashboard
#   2. Selecciona tu proyecto
#   3. Settings → API → "Project URL"
#   Formato: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
#
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# SUPABASE_KEY
#   Qué key usar: la "anon public" (NO la service_role)
#   Dónde encontrarla:
#   1. Settings → API → "Project API keys"
#   2. Copia el valor de "anon" / "public"
#   Empieza con: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXX


# ── RAILWAY / HTTP ────────────────────────────────────────────────────────────
#
# PORT — Railway lo inyecta automáticamente. Solo ponlo en local si
#         el puerto 8080 ya está ocupado en tu máquina.
#
PORT=8080


# ── TRADING ───────────────────────────────────────────────────────────────────
TRADING_PAIR=BTC/USDT

# Puntuación mínima (0-100) para emitir señal y enviar alerta
SIGNAL_SCORE_THRESHOLD=65

# Exchanges activos (true/false)
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true


# ── DETECCIÓN SPRING (valores por defecto recomendados) ───────────────────────
SPRING_DROP_PCT=0.003       # caída mínima 0.3%
SPRING_BOUNCE_PCT=0.002     # rebote mínimo 0.2%
SPRING_DROP_SECS=10         # ventana para la caída (segundos)
SPRING_BOUNCE_SECS=5        # ventana para el rebote (segundos)
VOLUME_MULTIPLIER=1.5       # volumen debe ser 1.5x el promedio
WINDOW_SECS=60              # ventana deslizante total (segundos)

# ── STOP CASCADE ──────────────────────────────────────────────────────────────
CASCADE_SELL_COUNT=200      # trades de venta para declarar cascade
CASCADE_SECS=5              # en cuántos segundos

# ── GESTIÓN DE RIESGO ─────────────────────────────────────────────────────────
STOP_LOSS_PCT=0.005         # stop loss 0.5% bajo el mínimo del Spring
RISK_REWARD=3.0             # ratio riesgo:beneficio (1:3)
